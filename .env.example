# Home Assistant
CLANKER_HA_URL=http://homeassistant.local:8123
CLANKER_HA_TOKEN=your_long_lived_access_token_here

# LLM Providers (set the ones you use)
CLANKER_ANTHROPIC_API_KEY=sk-ant-...
CLANKER_OPENAI_API_KEY=sk-...
CLANKER_OLLAMA_BASE_URL=http://localhost:11434

# Optional: OpenAI-compatible endpoint (llama.cpp, vLLM, etc.)
CLANKER_OPENAI_COMPAT_BASE_URL=http://localhost:8080/v1
CLANKER_OPENAI_COMPAT_API_KEY=

# Memory
CLANKER_MEMORY_DB_PATH=data/clanker.db
CLANKER_MEMORY_MARKDOWN_DIR=config/memory
CLANKER_CHROMADB_PATH=data/chroma

# Embedding model (for semantic memory via Ollama)
CLANKER_EMBEDDING_MODEL=nomic-embed-text
CLANKER_EMBEDDING_BASE_URL=http://localhost:11434
